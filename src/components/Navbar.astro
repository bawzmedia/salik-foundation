---
const { transparent = false } = Astro.props;
---

<nav class={`w-full ${transparent ? 'bg-transparent' : 'bg-black/90 backdrop-blur-sm border-b border-white/10'}`}>
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href="/">
      <img src="/salik-foundation-logo.png" alt="Salik Foundation" class="h-8 md:h-10" />
    </a>
    <div class="hidden items-center gap-6 text-sm tracking-wide text-white/70 md:flex">
      <a href="/about" class="transition-colors hover:text-white">About</a>
      <a href="/programs" class="transition-colors hover:text-white">Programs</a>
      <a href="/contact" class="transition-colors hover:text-white">Contact</a>
      <a
        href="/donate"
        class="rounded-sm border border-[#4AB3E2] bg-[#4AB3E2]/20 px-5 py-2 text-white shadow-[0_0_15px_rgba(74,179,226,0.2)] transition-all hover:bg-[#4AB3E2]/40 hover:shadow-[0_0_25px_rgba(74,179,226,0.4)]"
      >
        Donate
      </a>
    </div>
    <button
      class="text-white/70 md:hidden"
      aria-label="Open menu"
      id="page-menu-btn"
    >
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
</nav>

<!-- Mobile menu -->
<div id="page-mobile-menu" class="fixed inset-0 z-50 hidden bg-black/95 backdrop-blur-md md:hidden">
  <div class="flex h-full flex-col items-center justify-center gap-8">
    <a href="/about" class="text-2xl tracking-wide text-white/80 hover:text-white">About</a>
    <a href="/programs" class="text-2xl tracking-wide text-white/80 hover:text-white">Programs</a>
    <a href="/contact" class="text-2xl tracking-wide text-white/80 hover:text-white">Contact</a>
    <a href="/donate" class="mt-4 rounded-sm border border-[#4AB3E2] bg-[#4AB3E2]/20 px-10 py-4 text-xl tracking-[0.2em] uppercase text-white">
      Donate
    </a>
    <button class="mt-8 text-white/50" id="page-menu-close">Close</button>
  </div>
</div>

<script>
  document.getElementById('page-menu-btn')?.addEventListener('click', () => {
    document.getElementById('page-mobile-menu')?.classList.remove('hidden');
  });
  document.getElementById('page-menu-close')?.addEventListener('click', () => {
    document.getElementById('page-mobile-menu')?.classList.add('hidden');
  });
</script>
