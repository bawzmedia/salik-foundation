---
import PageLayout from '@/layouts/PageLayout.astro';
---

<PageLayout title="Programs - Salik Foundation" description="Explore the Salik Foundation's programs: Qur'an Project and Orphan Sponsorship.">
  <main class="min-h-screen bg-black text-white">
    <!-- Hero -->
    <section class="flex items-center justify-center bg-gradient-to-b from-[#1a1a2e] to-black px-6 py-32">
      <div class="max-w-3xl text-center">
        <h1 class="text-4xl font-light tracking-wide md:text-5xl" style="font-family: Georgia, serif;">
          Programs & Initiatives
        </h1>
        <p class="mt-6 text-lg text-white/70">
          Dedicated to sharing the divine guidance of the Qur'an with communities worldwide and uplifting orphans through care and education.
        </p>
      </div>
    </section>

    <!-- Programs -->
    <section class="px-6 py-20">
      <div class="mx-auto max-w-4xl space-y-16">
        <!-- Qur'an Project -->
        <div class="rounded-lg border border-white/10 bg-white/5 p-8 md:p-12">
          <div class="mb-4 inline-block rounded-sm bg-[#4AB3E2]/20 px-3 py-1 text-xs tracking-[0.2em] uppercase text-[#4AB3E2]">
            Core Program
          </div>
          <h2 class="text-3xl font-light tracking-wide" style="font-family: Georgia, serif;">
            Qur'an Project
          </h2>
          <p class="mt-4 text-lg leading-relaxed text-white/70">
            Delivering the message of the Qur'an to communities worldwide. Through distribution, education programs, and community outreach, we ensure that the timeless guidance of the Qur'an reaches those who seek it.
          </p>
          <a
            href="/donate"
            class="mt-6 inline-block rounded-sm border border-[#4AB3E2] bg-[#4AB3E2]/20 px-8 py-3 tracking-[0.15em] uppercase text-white transition-all hover:bg-[#4AB3E2]/40"
          >
            Support This Program
          </a>
        </div>

        <!-- Orphan Sponsorship -->
        <div class="rounded-lg border border-white/10 bg-white/5 p-8 md:p-12">
          <div class="mb-4 inline-block rounded-sm bg-[#D4A843]/20 px-3 py-1 text-xs tracking-[0.2em] uppercase text-[#D4A843]">
            Core Program
          </div>
          <h2 class="text-3xl font-light tracking-wide" style="font-family: Georgia, serif;">
            Orphan Sponsorship
          </h2>
          <p class="mt-4 text-lg leading-relaxed text-white/70">
            Providing monthly support, education, and healthcare for orphaned children to ensure their bright future. Your sponsorship gives a child access to nutrition, education, medical care, and a safe environment to grow.
          </p>
          <a
            href="/donate"
            class="mt-6 inline-block rounded-sm border border-[#D4A843] bg-[#D4A843]/20 px-8 py-3 tracking-[0.15em] uppercase text-white transition-all hover:bg-[#D4A843]/40"
          >
            Sponsor an Orphan
          </a>
        </div>
      </div>
    </section>

    <!-- Get Involved -->
    <section class="bg-[#4AB3E2]/10 px-6 py-20">
      <div class="mx-auto max-w-4xl">
        <h2 class="text-center text-3xl font-light tracking-wide" style="font-family: Georgia, serif;">
          Get Involved
        </h2>
        <div class="mt-12 grid gap-8 md:grid-cols-3">
          <div class="rounded-lg border border-white/10 bg-black/40 p-8 text-center">
            <div class="mb-4 text-3xl">💝</div>
            <h3 class="text-lg font-light tracking-wide">Donate</h3>
            <p class="mt-2 text-sm text-white/60">Support our mission with your generous contribution</p>
            <a href="/donate" class="mt-4 inline-block text-sm text-[#4AB3E2] hover:underline">Donate Now →</a>
          </div>
          <div class="rounded-lg border border-white/10 bg-black/40 p-8 text-center">
            <div class="mb-4 text-3xl">🤝</div>
            <h3 class="text-lg font-light tracking-wide">Volunteer</h3>
            <p class="mt-2 text-sm text-white/60">Join our team and make a direct impact</p>
            <a href="/contact" class="mt-4 inline-block text-sm text-[#4AB3E2] hover:underline">Join Us →</a>
          </div>
          <div class="rounded-lg border border-white/10 bg-black/40 p-8 text-center">
            <div class="mb-4 text-3xl">❤️</div>
            <h3 class="text-lg font-light tracking-wide">Sponsor an Orphan</h3>
            <p class="mt-2 text-sm text-white/60">Change a child's life with monthly sponsorship</p>
            <a href="/donate" class="mt-4 inline-block text-sm text-[#4AB3E2] hover:underline">Sponsor Today →</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</PageLayout>
